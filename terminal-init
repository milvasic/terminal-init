#!/usr/bin/env bash
# terminal-init — first-time terminal environment setup for Debian/Ubuntu
# https://github.com/milvasic/terminal-init

set -euo pipefail

VERSION="0.2.0"

# ── Help ──────────────────────────────────────────────────────────────────────
help() {
	colorize >&2 <<'EOF'
A single-file Bash CLI for first-time terminal environment setup on Debian/Ubuntu.

Usage:
  terminal-init <command>

Commands:
  ensure-tools              # Full first-time setup (packages, OMZ/Zinit, zsh, configs)
  ensure-config             # Re-write config files only (.zshrc, .spaceshiprc.zsh)
  update                    # Update terminal-init to the latest version
  version, --version, -v    # Print version
  help, --help, -h          # Show this message

Description:
  On first run, 'ensure-tools' will:
  1. Install base packages (curl, git, zsh, ncdu)
  2. Install oh-my-zsh and Zinit plugin manager
  3. Set zsh as the default shell
  4. Configure ~/.zshrc with plugins and prompt theme
  5. Configure ~/.config/.spaceshiprc.zsh for Spaceship prompt
  6. Install motd for system dashboard at login
  7. Install mcli for service management

  'ensure-config' can be run later to regenerate config files without re-installing packages.

  After running, restart your terminal or log out/in to activate zsh.
EOF
	exit 1
}

# ── Colors & logging ──────────────────────────────────────────────────────────
if [ -t 1 ]; then
	RED=$'\033[0;31m'
	GREEN=$'\033[0;32m'
	YELLOW=$'\033[0;33m'
	CYAN=$'\033[0;36m'
	BOLD=$'\033[1m'
	RESET=$'\033[0m'
else
	RED=""
	GREEN=""
	YELLOW=""
	CYAN=""
	BOLD=""
	RESET=""
fi

log() { printf "\n${BOLD}=== %s ===${RESET}\n" "$1" >&2; }
error() { printf "${RED}ERROR:${RESET} %s\n" "$1" >&2; }
ok() { printf "${GREEN}%s${RESET}\n" "$1"; }
info() { printf "${CYAN}%s${RESET}\n" "$1"; }
skip() { printf "${YELLOW}[skip]${RESET} %s\n" "$1"; }
step() { printf "${BOLD}[step]${RESET} %s\n" "$1"; }

# ── Help colorizer ────────────────────────────────────────────────────────────
colorize_line() {
	sed \
		-e "s/\\(^\\|[^[:alnum:]_'-]\\)\\(terminal-init\\)\\([^[:alnum:]_'-]\\|$\\)/\\1${GREEN}\\2${RESET}\\3/g" \
		-e "s/\\(^\\|[^[:alnum:]_'-]\\)\\(ensure-tools\\|ensure-config\\|update\\|version\\|help\\)\\([^[:alnum:]_'-]\\|$\\)/\\1${YELLOW}\\2${RESET}\\3/g" \
		-e "s/--[a-z][a-z-]*/${CYAN}&${RESET}/g" \
		-e "s/\([ ,]\)\(-[a-z]\)/\\1${CYAN}\\2${RESET}/g"
}

colorize() {
	local line pre post
	while IFS= read -r line; do
		if [[ "$line" == *'#'* ]]; then
			pre="${line%%#*}"
			post="${line#*#}"
			pre="$(printf '%s' "$pre" | colorize_line)"
			printf '%s%s#%s%s\n' "$pre" "$GREEN" "$post" "$RESET"
		else
			printf '%s\n' "$line" | colorize_line
		fi
	done
}

# ── Helpers ───────────────────────────────────────────────────────────────────
report_error() {
	error "$1 failed. Continuing..."
}

# ── Prerequisite check ────────────────────────────────────────────────────────
if ! command -v apt >/dev/null 2>&1; then
	error "This script requires apt. Debian/Ubuntu only."
	exit 1
fi

USER_HOME="$HOME"
ZSHRC="$USER_HOME/.zshrc"
SPACESHIP_CFG="$USER_HOME/.config/.spaceshiprc.zsh"

# ── ensure-config ─────────────────────────────────────────────────────────────
ensure_config() {
	# ── Write .zshrc ──────────────────────────────────────────────────────────
	step "Creating ~/.zshrc ..."

	if [ -f "$ZSHRC" ]; then
		cp "$ZSHRC" "${ZSHRC}.bak"
		info "Backed up existing .zshrc to ${ZSHRC}.bak"
	fi

	if cat >"$ZSHRC" <<'EOF'; then
export ZSH="$HOME/.oh-my-zsh"
export PATH=/usr/sbin:$PATH
export ZSH_COMPDUMP=$ZSH/cache/.zcompdump-$HOST
export SPACESHIP_CONFIG="$HOME/.config/.spaceshiprc.zsh"

# export NVM_DIR="$HOME/.nvm"
# [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
# [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# alias python="python3"
ZSH_THEME=""
plugins=(git docker docker-compose)

source $ZSH/oh-my-zsh.sh

### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Plugin Manager …%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

zinit light spaceship-prompt/spaceship-prompt
zinit light zdharma-continuum/fast-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-completions

alias clear-shell-history="echo '' > ~/.zsh_history"
alias clear-journal="sudo journalctl --rotate && sudo journalctl --vacuum-time=1s"
alias disk-usage="cd / && sudo ncdu && cd - > /dev/null"
alias dps="docker ps -a --format \"table {{.Names}}\t{{.State}}\t{{.Status}}\t{{.Size}}\""
alias dpsp="docker ps -a --format \"table {{.Names}}\t{{.State}}\t{{.Status}}\t{{.Size}}\t{{.Ports}}\""
alias listen-ports="sudo lsof -i -P -n | grep LISTEN"

command -v motd >/dev/null && motd
EOF
		ok ".zshrc created."
	else
		report_error ".zshrc creation"
	fi

	# ── Create ~/.config/.spaceshiprc.zsh ──────────────────────────────────────
	step "Creating spaceship configuration..."

	mkdir -p "$USER_HOME/.config"

	if [ -f "$SPACESHIP_CFG" ]; then
		cp "$SPACESHIP_CFG" "${SPACESHIP_CFG}.bak"
		info "Backed up existing .spaceshiprc.zsh to ${SPACESHIP_CFG}.bak"
	fi

	if cat >"$SPACESHIP_CFG" <<'EOF'; then
SPACESHIP_USER_SHOW=always
SPACESHIP_HOST_SHOW=always
SPACESHIP_TIME_SHOW=true
SPACESHIP_CHAR_SYMBOL_ROOT="# "

SPACESHIP_HG_SHOW=false
SPACESHIP_HG_BRANCH_SHOW=false
SPACESHIP_HG_STATUS_SHOW=false
SPACESHIP_PACKAGE_SHOW=false
SPACESHIP_RUBY_SHOW=false
SPACESHIP_ELM_SHOW=false
SPACESHIP_XCODE_SHOW_LOCAL=false
SPACESHIP_SWIFT_SHOW_LOCAL=false
SPACESHIP_GOLANG_SHOW=false
SPACESHIP_PHP_SHOW=false
SPACESHIP_RUST_SHOW=false
SPACESHIP_HASKELL_SHOW=false
SPACESHIP_JULIA_SHOW=false
SPACESHIP_DOCKER_CONTEXT_SHOW=false
SPACESHIP_AWS_SHOW=false
SPACESHIP_VENV_SHOW=false
SPACESHIP_CONDA_SHOW=false
SPACESHIP_PYTHON_SHOW=false
SPACESHIP_EMBER_SHOW=false
SPACESHIP_KUBECTL_SHOW=false
SPACESHIP_KUBECTL_CONTEXT_SHOW=false
SPACESHIP_TERRAFORM_SHOW=false
SPACESHIP_BATTERY_SHOW=false
SPACESHIP_VI_MODE_SHOW=false
SPACESHIP_JOBS_SHOW=false
SPACESHIP_EXIT_CODE_SHOW=false

SPACESHIP_PROMPT_ORDER=(host time user dir git node dotnet docker exec_time char)
EOF
		ok "Spaceship config created."
	else
		report_error "spaceship config creation"
	fi
}

# ── ensure-tools ──────────────────────────────────────────────────────────────
ensure_tools() {
	log "terminal-init ensure-tools"

	# ── Install required packages ─────────────────────────────────────────────
	step "Checking base packages (curl git zsh ncdu)..."

	missing_pkgs=""
	command -v curl >/dev/null 2>&1 || missing_pkgs="$missing_pkgs curl"
	command -v git >/dev/null 2>&1 || missing_pkgs="$missing_pkgs git"
	command -v zsh >/dev/null 2>&1 || missing_pkgs="$missing_pkgs zsh"
	command -v ncdu >/dev/null 2>&1 || missing_pkgs="$missing_pkgs ncdu"

	if [ -n "$missing_pkgs" ]; then
		info "Missing packages:$missing_pkgs"
		if sudo apt update && sudo apt install -y $missing_pkgs; then
			ok "Packages installed."
		else
			report_error "Package installation"
		fi
	else
		skip "All base packages already installed."
	fi

	# ── Install oh-my-zsh ─────────────────────────────────────────────────────
	step "Installing oh-my-zsh..."

	if [ -d "$HOME/.oh-my-zsh" ]; then
		skip "oh-my-zsh already installed."
	elif RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"; then
		ok "oh-my-zsh installed."
	else
		report_error "oh-my-zsh installation"
	fi

	# ── Set zsh as default shell ──────────────────────────────────────────────
	step "Setting zsh as default shell..."

	if [ "$SHELL" = "$(command -v zsh)" ]; then
		skip "zsh is already the default shell."
	elif chsh -s "$(command -v zsh)"; then
		ok "Shell changed to zsh."
	else
		report_error "chsh command"
	fi

	# ── Write config files ────────────────────────────────────────────────────
	ensure_config

	# ── Install motd ──────────────────────────────────────────────────────────
	step "Installing motd..."

	if command -v motd >/dev/null 2>&1; then
		skip "motd already installed."
	elif bash -c "$(curl -fsSL https://raw.githubusercontent.com/milvasic/motd/refs/heads/main/install.sh)" -- --yes; then
		ok "motd installed."
	else
		report_error "motd installation"
	fi

	# ── Install mcli ──────────────────────────────────────────────────────────
	step "Installing mcli..."

	if command -v mcli >/dev/null 2>&1; then
		skip "mcli already installed."
	elif bash -c "$(curl -fsSL https://raw.githubusercontent.com/milvasic/mcli/refs/heads/main/install.sh)" -- --yes; then
		ok "mcli installed."
	else
		report_error "mcli installation"
	fi

	log "Installation complete"
	ok "Restart your terminal or log out/in to activate zsh."
}

# ── Update command ────────────────────────────────────────────────────────────
INSTALLER_SELF_URL="https://raw.githubusercontent.com/milvasic/terminal-init/refs/heads/main/install.sh"
update() {
	if command -v curl >/dev/null 2>&1; then
		bash -c "$(curl -fsSL "${INSTALLER_SELF_URL}")" -- --yes
	elif command -v wget >/dev/null 2>&1; then
		bash -c "$(wget -qO- "${INSTALLER_SELF_URL}")" -- --yes
	else
		error "Neither curl nor wget found. Please install one and try again."
		exit 1
	fi
}

# ── Main dispatch ─────────────────────────────────────────────────────────────
COMMAND="${1:-}"
[ $# -ge 1 ] && shift

case "$COMMAND" in
ensure-tools)
	ensure_tools
	;;
ensure-config)
	ensure_config
	;;
update)
	update
	;;
version | --version | -v)
	echo "${VERSION}"
	;;
help | --help | -h)
	help
	;;
*)
	error "Unknown command: ${COMMAND:-<none>}"
	help
	;;
esac
